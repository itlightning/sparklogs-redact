{
  "name": "@sparklogs/redact-core",
  "version": "0.2.1",
  "description": "Isomorphic core: detect and consistently pseudonymise PII in log text, with a residual-PII scanner. Pure string/regex — safe in Node or the browser. Driven by portable JSON detection specs.",
  "license": "MIT",
  "author": "IT Lightning, LLC (https://sparklogs.com)",
  "homepage": "https://github.com/itlightning/sparklogs-redact/tree/main/packages/redact-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itlightning/sparklogs-redact.git",
    "directory": "packages/redact-core"
  },
  "bugs": {
    "url": "https://github.com/itlightning/sparklogs-redact/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./patterns/windows-log.json": "./patterns/windows-log.json",
    "./patterns/generic.json": "./patterns/generic.json",
    "./patterns/secret.json": "./patterns/secret.json"
  },
  "files": [
    "dist",
    "patterns"
  ],
  "scripts": {
    "test": "node --test",
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pii",
    "redaction",
    "anonymization",
    "pseudonymization",
    "logs",
    "windows",
    "cbs",
    "gdpr",
    "privacy",
    "isomorphic"
  ]
}
